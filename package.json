{
  "name": "testing-tool-for-all-project",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable Playwright and Vitest quality engineering framework for web applications and APIs.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "playwright test --ui",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:mocked": "playwright test --project=mocked",
    "test:e2e:integrated": "playwright test --project=integrated",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "verify": "npm run lint && npm run typecheck && npm run test:unit && npm run test:e2e && npm run build",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "playwright-core": "^1.61.1"
  }
}
