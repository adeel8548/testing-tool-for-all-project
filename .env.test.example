# Never commit real credentials. Use an isolated test account.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_USER_ROLE=user
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

# Optional role-based audit accounts (never place real values in Git).
TEST_ADMIN_USERNAME=
TEST_MANAGER_USERNAME=
TEST_MANAGER_PASSWORD=
TEST_USER_USERNAME=

# Optional bearer token for API-integrated tests
TEST_API_TOKEN=

# Safety switches. Real-data mutations remain disabled unless explicitly enabled.
RUN_INTEGRATED_TESTS=false
RUN_AUTH_TESTS=false
ALLOW_TEST_MUTATIONS=false
